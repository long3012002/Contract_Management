## Ignore Visual Studio temporary files, build results, and files generated by popular VS add-ons.
# User-specific files
*.rsuser
*.suo
*.user
*.userresource
*.userpre
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Log]/
[Log]s/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# Visual Studio Code cache directory
.vscode/

# Rider cache directory
.idea/

# Auto-generated files by EF migrations or DB context
# *.db
# *.sqlite

# UserSecrets
# appsettings.Development.json
# appsettings.json

# Docker
.dockerignore
Dockerfile

# Node / Frontend ignores
node_modules/
dist/
.env
.env.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Agent skills
.agents/
skill-lock.json


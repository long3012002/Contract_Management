r-slate-200 rounded-xl text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors\" data-kid=\"54\">\n            <i class=\"ti ti-filter\" data-kid=\"55\"></i>\n            Bộ lọc\n          </button>\n        </div>\n\n        <table class=\"w-full text-left border-collapse\" data-kid=\"56\">\n          <thead data-kid=\"57\">\n            <tr class=\"bg-slate-50/50\" data-kid=\"58\">\n              <th class=\"px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"59\">Tên người dùng</th>\n              <th class=\"px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"60\">Địa chỉ Email</th>\n              <th class=\"px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"61\">Nhóm quyền hạn</th>\n              <th class=\"px-6 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-wider text-right\" data-kid=\"62\">Thao tác</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-slate-100\" data-kid=\"63\">\n            <tr class=\"hover:bg-[#F0F9FF] transition-colors group\" data-kid=\"64\">\n              <td class=\"px-6 py-4\" data-kid=\"65\">\n                <div class=\"flex items-center gap-3\" data-kid=\"66\">\n                  <div class=\"w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center font-bold text-xs text-slate-600\" data-kid=\"67\">NV</div>\n                  <span class=\"font-semibold text-slate-900\" data-kid=\"68\">Nguyễn Văn A</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-4 text-slate-500 text-sm\" data-kid=\"69\">a@coopbank.vn</td>\n              <td class=\"px-6 py-4\" data-kid=\"70\">\n                <div class=\"flex items-center gap-2\" data-kid=\"71\">\n                  <span class=\"px-2.5 py-1 bg-[#F0F9FF] text-[#00377B] text-xs font-semibold rounded-lg border border-[#00377B]/10\" data-kid=\"72\">Kế toán</span>\n                  <span class=\"px-2.5 py-1 bg-[#F0F9FF] text-[#00377B] text-xs font-semibold rounded-lg border border-[#00377B]/10\" data-kid=\"73\">Quản trị</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"74\">\n                <button class=\"inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-[#00377B] hover:bg-[#00377B] hover:text-white rounded-lg transition-all\" data-kid=\"75\">\n                  <i class=\"ti ti-edit-2\" data-kid=\"76\"></i>\n                  Sửa\n                </button>\n              </td>\n            </tr>\n            <tr class=\"hover:bg-[#F0F9FF] transition-colors group\" data-kid=\"77\">\n              <td class=\"px-6 py-4\" data-kid=\"78\">\n                <div class=\"flex items-center gap-3\" data-kid=\"79\">\n                  <div class=\"w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center font-bold text-xs text-slate-600\" data-kid=\"80\">TT</div>\n                  <span class=\"font-semibold text-slate-900\" data-kid=\"81\">Trần Thị B</span>\n                </div>\n              </td>\n              <td class=\"px-6 py-4 text-slate-500 text-sm\" data-kid=\"82\">b@coopbank.vn</td>\n              <td class=\"px-6 py-4\" data-kid=\"83\">\n                <span class=\"px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-lg border border-slate-200\" data-kid=\"84\">Kỹ thuật</span>\n              </td>\n              <td class=\"px-6 py-4 text-right\" data-kid=\"85\">\n                <button class=\"inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-[#00377B] hover:bg-[#00377B] hover:text-white rounded-lg transition-all\" data-kid=\"86\">\n                  <i class=\"ti ti-edit-2\" data-kid=\"87\"></i>\n                  Sửa\n                </button>\n              </td>\n            </tr>\n            <tr class=\"hover:bg-[#F0F9FF] transition-colors group\" data-kid=\"88\">\n              <td class=\"px-6 py-4\" da
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --coopbank-navy: #00377B;\n    --coopbank-navy-dark: #002D62;\n    --bg-main: #F8FAFC;\n    --font-display: 'Be Vietnam Pro', sans-serif;\n    --font-data: 'Roboto', sans-serif;\n  }\n\n  .font-display { font-family: var(--font-display); }\n  .font-data { font-family: var(--font-data); }\n  \n  /* Scrollbar styling for a professional look */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #CBD5E1;\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #94A3B8;\n  }\n</style>\n\n<div class=\"flex min-h-screen bg-[var(--bg-main)] font-data text-slate-900\" data-kid=\"1\">\n  \n  <aside class=\"w-64 bg-[var(--coopbank-navy)] flex-shrink-0 flex flex-col sticky top-0 h-screen\" data-kid=\"2\">\n    <div class=\"p-6\" data-kid=\"3\">\n      <img src=\"/api/local/images/frontend/src/assets/logo/logo_Co-opBank.png\" alt=\"Co-opBank\" class=\"h-10 object-contain brightness-0 invert\" data-kid=\"4\">\n    </div>\n    \n    <nav class=\"flex-1 px-4 space-y-1 mt-4\" data-kid=\"5\">\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all group\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-xl\" data-kid=\"7\"></i>\n        <span class=\"font-medium\" data-kid=\"8\">Tổng quan</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all\" data-kid=\"9\">\n        <i class=\"ti ti-file-text text-xl\" data-kid=\"10\"></i>\n        <span class=\"font-medium\" data-kid=\"11\">Hợp đồng</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all\" data-kid=\"12\">\n        <i class=\"ti ti-users-group text-xl\" data-kid=\"13\"></i>\n        <span class=\"font-medium\" data-kid=\"14\">Đối tác</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 bg-white/15 text-white rounded-lg transition-all\" data-kid=\"15\">\n        <i class=\"ti ti-shield-lock text-xl\" data-kid=\"16\"></i>\n        <span class=\"font-medium\" data-kid=\"17\">Phân quyền</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all\" data-kid=\"18\">\n        <i class=\"ti ti-chart-bar text-xl\" data-kid=\"19\"></i>\n        <span class=\"font-medium\" data-kid=\"20\">Báo cáo</span>\n      </a>\n    </nav>\n    \n    <div class=\"p-4 border-t border-white/10\" data-kid=\"21\">\n      <a href=\"#\" class=\"flex items-center gap-3 px-4 py-3 text-white/70 hover:text-white hover:bg-white/10 rounded-lg transition-all\" data-kid=\"22\">\n        <i class=\"ti ti-settings text-xl\" data-kid=\"23\"></i>\n        <span class=\"font-medium\" data-kid=\"24\">Cài đặt</span>\n      </a>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col min-w-0\" data-kid=\"25\">\n    \n    <header class=\"h-16 bg-white border-b border-slate-200 px-8 flex items-center justify-between sticky top-0 z-10\" data-kid=\"26\">\n      <div class=\"flex items-center gap-2 text-sm text-slate-500\" data-kid=\"27\">\n        <span class=\"hover:text-slate-800 cursor-pointer\" data-kid=\"28\">Dashboard</span>\n        <i class=\"ti ti-chevron-right text-xs\" data-kid=\"29\"></i>\n        <span class=\"text-slate-900 font-medium\" data-kid=\"30\">Quản trị phân quyền</span>\n      </div>\n      \n      <div class=\"flex items-center gap-6\" data-kid=\"31\"
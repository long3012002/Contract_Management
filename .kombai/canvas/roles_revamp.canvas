      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-coopbank: #00377B;\n    --font-display: \"Be Vietnam Pro\", sans-serif;\n    --font-sans: \"Roboto\", sans-serif;\n  }\n\n  body {\n    margin: 0;\n    font-family: var(--font-sans);\n    background-color: #F8FAFC;\n    color: #1E293B;\n  }\n\n  .font-display { font-family: var(--font-display); }\n</style>\n\n<div class=\"flex min-h-screen\" data-kid=\"1\">\n  \n  <aside class=\"w-64 bg-[var(--color-coopbank)] text-white flex flex-col shrink-0\" data-kid=\"2\">\n    <div class=\"p-6\" data-kid=\"3\">\n      <div class=\"bg-white rounded p-2 inline-block\" data-kid=\"4\">\n        <img src=\"/api/local/images/frontend/src/assets/logo/logo_Co-opBank.png\" alt=\"Co-opBank\" class=\"h-8 w-auto\" decoding=\"async\" loading=\"lazy\" data-kid=\"5\">\n      </div>\n    </div>\n    \n    <nav class=\"mt-4 flex-1\" data-kid=\"6\">\n      <a href=\"#\" class=\"flex items-center gap-3 px-6 py-3 text-white/70 hover:bg-white/10 hover:text-white transition-colors\" data-kid=\"7\">\n        <i class=\"ti ti-layout-dashboard text-lg\" data-kid=\"8\"></i>\n        <span class=\"font-medium\" data-kid=\"9\">Tổng quan</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-6 py-3 text-white/70 hover:bg-white/10 hover:text-white transition-colors\" data-kid=\"10\">\n        <i class=\"ti ti-file-text text-lg\" data-kid=\"11\"></i>\n        <span class=\"font-medium\" data-kid=\"12\">Hợp đồng</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-3 px-6 py-3 text-white/70 hover:bg-white/10 hover:text-white transition-colors\" data-kid=\"13\">\n        <i class=\"ti ti-users text-lg\" data-kid=\"14\"></i>\n        <span class=\"font-medium\" data-kid=\"15\">Đối tác<
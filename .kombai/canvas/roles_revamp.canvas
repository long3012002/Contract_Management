"flex items-center gap-3\" data-kid=\"36\">\n          <button class=\"relative p-2 text-slate-500 hover:bg-slate-100 rounded-full transition-colors\" data-kid=\"37\">\n            <i class=\"ti ti-bell text-xl\" data-kid=\"38\"></i>\n            <span class=\"absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white\" data-kid=\"39\"></span>\n          </button>\n          <div class=\"flex items-center gap-2 pl-4 border-l border-slate-200\" data-kid=\"40\">\n            <div class=\"w-8 h-8 rounded-full bg-[var(--color-coopbank)] text-white flex items-center justify-center font-bold text-xs\" data-kid=\"41\">CB</div>\n            <span class=\"text-sm font-semibold text-slate-700\" data-kid=\"42\">Admin</span>\n          </div>\n        </div>\n      </div>\n    </header>\n\n    \n    <section class=\"bg-[var(--color-coopbank)] px-8 pt-8 pb-0 shrink-0\" data-kid=\"43\">\n      <div class=\"flex justify-between items-end\" data-kid=\"44\">\n        <div data-kid=\"45\">\n          <h1 class=\"font-display text-3xl font-bold text-white tracking-tight\" data-kid=\"46\">Quản trị phân quyền</h1>\n          <p class=\"text-white/60 mt-1 text-sm max-w-md\" data-kid=\"47\">Quản lý vai trò, quyền hạn và truy cập hệ thống của người dùng một cách chính xác và bảo mật.</p>\n        </div>\n      </div>\n\n      \n      <div class=\"flex gap-8 mt-8\" data-kid=\"48\">\n        <button class=\"relative pb-4 text-sm font-semibold text-white outline-none\" data-kid=\"49\">\n          Người dùng\n          <span class=\"absolute bottom-0 left-0 right-0 h-1 bg-white rounded-t-full\" data-kid=\"50\"></span>\n        </button>\n        <button class=\"pb-4 text-sm font-medium text-white/50 hover:text-white/80 transition-colors outline-none\" data-kid=\"51\">\n          Cấu hình nhóm quyền\n        </button>\n      </div>\n    </section>\n\n    \n    <div class=\"p-8 flex-1 overflow-auto\" data-kid=\"52\">\n      <div class=\"bg-white border border-slate-200 roun
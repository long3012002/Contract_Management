kid=\"49\">Người dùng</span>\n          <div class=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[var(--coopbank-navy)] rounded-full\" data-kid=\"50\"></div>\n        </button>\n        <button class=\"pb-4 text-sm font-medium text-slate-500 hover:text-slate-800 transition-all\" data-kid=\"51\">\n          <span data-kid=\"52\">Cấu hình nhóm quyền</span>\n        </button>\n      </div>\n\n      \n      <div class=\"bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm\" data-kid=\"53\">\n        \n        <div class=\"p-4 border-b border-slate-200 flex items-center justify-between bg-slate-50/50\" data-kid=\"54\">\n          <div class=\"relative w-80\" data-kid=\"55\">\n            <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400\" data-kid=\"56\"></i>\n            <input type=\"text\" placeholder=\"Tìm kiếm người dùng bằng tên hoặc email...\" class=\"w-full bg-white border border-slate-200 rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-[var(--coopbank-navy)]/20 focus:border-[var(--coopbank-navy)] outline-none transition-all\" data-kid=\"57\">\n          </div>\n          <div class=\"flex items-center gap-3\" data-kid=\"58\">\n            <button class=\"flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-all\" data-kid=\"59\">\n              <i class=\"ti ti-filter\" data-kid=\"60\"></i>\n              <span data-kid=\"61\">Lọc</span>\n            </button>\n            <button class=\"px-4 py-2 text-sm font-semibold text-white bg-[var(--coopbank-navy)] rounded-lg hover:bg-[var(--coopbank-navy-dark)] transition-all shadow-md shadow-navy-900/10\" data-kid=\"62\">\n              + Thêm người dùng\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"overflow-x-auto\" data-kid=\"63\">\n          <table class=\"w-full text-left border-collapse font-data\" data-kid=\"64\">\n            